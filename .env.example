# Public HTTP port exposed by Docker on the NAS.
SWIMDASH_PUBLIC_PORT=8766

# Shared admin password for /admin.html login.
SWIMDASH_ADMIN_PASSWORD=

# Required when admin protection is enabled.
SWIMDASH_ADMIN_SESSION_SECRET=

# Set to 1 when Synology reverse proxy terminates HTTPS in front of the container.
SWIMDASH_SECURE_COOKIES=0

# Default admin login lifetime is 12 hours.
SWIMDASH_ADMIN_SESSION_TTL_SECONDS=43200

# Keep the container timezone aligned with the NAS schedule.
TZ=Asia/Seoul

# Optional Gemini OCR candidate extraction.
# Keep disabled unless you intentionally want OCR candidates during crawl/refresh.
SWIMDASH_ENABLE_GEMINI_OCR=0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_OCR_MIN_CONFIDENCE=0.85
GEMINI_OCR_MAX_IMAGES_PER_POST=3
GEMINI_OCR_MAX_CALLS_PER_RUN=30
GEMINI_OCR_CACHE_DIR=data/ocr_cache
